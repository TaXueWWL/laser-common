<?xml version="1.0" encoding="UTF-8"?>
<messageSchema xmlns="http://fixprotocol.io/2016/SBE"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://fixprotocol.io/2016/SBE http://fixprotocol.io/2016/SBE"
               package="com.laser.matching.common.codec"
               id="2"
               version="0"
               semanticVersion="1.0.0"
               byteOrder="littleEndian">
    <types>
        <!-- 标准 SBE 消息头 -->
        <composite name="messageHeader" description="Standard SBE message header.">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <!-- 变长字符串编码 -->
        <composite name="varStringEncoding" description="Variable length UTF-8 string.">
            <type name="length" primitiveType="uint32" maxValue="1048576"/>
            <type name="varData" primitiveType="uint8" length="0" characterEncoding="UTF-8"/>
        </composite>

        <!-- ====================== 枚举定义 ====================== -->

        <!-- 布尔类型 -->
        <enum name="BooleanType" encodingType="uint8">
            <validValue name="FALSE">0</validValue>
            <validValue name="TRUE">1</validValue>
        </enum>

        <!-- 订单类型: LIMIT=1(限价单), MARKET=2(市价单) -->
        <enum name="OrderType" encodingType="uint8">
            <validValue name="LIMIT">1</validValue>
            <validValue name="MARKET">2</validValue>
        </enum>

        <!-- 买卖方向: BUY=1(买单), SELL=2(卖单) -->
        <enum name="OrderSide" encodingType="uint8">
            <validValue name="BUY">1</validValue>
            <validValue name="SELL">2</validValue>
        </enum>

        <!-- 订单生效类型: GTC/IOC/FOK/POST_ONLY -->
        <enum name="TimeInForce" encodingType="uint8">
            <validValue name="GTC">1</validValue>
            <validValue name="IOC">2</validValue>
            <validValue name="FOK">3</validValue>
            <validValue name="POST_ONLY">4</validValue>
        </enum>

        <!-- 自成交保护策略: DEFAULT/CANCEL_MAKER/CANCEL_TAKER/CANCEL_BOTH -->
        <enum name="StpStrategy" encodingType="uint8">
            <validValue name="DEFAULT">0</validValue>
            <validValue name="CANCEL_MAKER">1</validValue>
            <validValue name="CANCEL_TAKER">2</validValue>
            <validValue name="CANCEL_BOTH">3</validValue>
        </enum>

        <!-- 订单状态 -->
        <enum name="OrderStatus" encodingType="uint8">
            <validValue name="NEW">1</validValue>
            <validValue name="CANCELLED">2</validValue>
            <validValue name="PARTIALLY_FILLED">3</validValue>
            <validValue name="FULL_FILLED">4</validValue>
            <validValue name="REJECTED">5</validValue>
        </enum>

        <!-- 撤单原因 -->
        <enum name="CancelReason" encodingType="uint8">
            <validValue name="NONE">0</validValue>
            <validValue name="POST_ONLY_CROSS">1</validValue>
            <validValue name="IOC_NOT_CROSS">2</validValue>
            <validValue name="FOK_NOT_CROSS">3</validValue>
            <validValue name="STP_CANCEL">4</validValue>
            <validValue name="IOC_NOT_FULLFILL_CANCEL_REMAINING">5</validValue>
            <validValue name="FOK_NOT_FULLFILL_CANCEL">6</validValue>
        </enum>
    </types>

    <!-- ====================== 指令定义 ====================== -->

    <!-- 下单指令: field(定长)在前, data(变长)在后 -->
    <message name="PlaceOrderCommand" id="100" description="下单指令">
        <!-- 定长 field -->
        <field name="orderId" id="1" type="uint64"/>
        <field name="accountId" id="2" type="uint64"/>
        <field name="symbolCode" id="3" type="uint16"/>
        <field name="orderType" id="4" type="OrderType"/>
        <field name="orderSide" id="5" type="OrderSide"/>
        <field name="timeInForce" id="6" type="TimeInForce"/>
        <field name="stpAccountId" id="7" type="uint64"/>
        <field name="stpStrategy" id="8" type="StpStrategy"/>
        <data name="delegatePrice" id="9" type="varStringEncoding"/>
        <data name="delegateCount" id="10" type="varStringEncoding"/>
        <data name="clientOid" id="11" type="varStringEncoding"/>
    </message>

    <!-- 改单指令 -->
    <message name="AmendOrderCommand" id="101" description="改单指令">
        <!-- 定长 field -->
        <field name="orderId" id="1" type="uint64"/>
        <field name="symbolCode" id="2" type="uint16"/>
        <!-- 变长 data -->
        <data name="newDelegatePrice" id="3" type="varStringEncoding"/>
        <data name="newDelegateCount" id="4" type="varStringEncoding"/>
    </message>

    <!-- 撤单指令 -->
    <message name="CancelOrderCommand" id="102" description="撤单指令">
        <!-- 定长 field -->
        <field name="orderId" id="1" type="uint64"/>
        <field name="symbolCode" id="2" type="uint16"/>
    </message>
</messageSchema>