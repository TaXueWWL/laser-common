<?xml version="1.0" encoding="UTF-8"?>
<messageSchema xmlns="http://fixprotocol.io/2016/SBE"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="http://fixprotocol.io/2016/SBE http://fixprotocol.io/2016/SBE"
               package="com.laser.matching.common.codec.snapshot"
               id="3"
               version="0"
               semanticVersion="1.0.0"
               byteOrder="littleEndian">
    <types>
        <composite name="messageHeader" description="Standard SBE message header.">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <composite name="varStringEncoding" description="Variable length UTF-8 string.">
            <type name="length" primitiveType="uint32" maxValue="1048576"/>
            <type name="varData" primitiveType="uint8" length="0" characterEncoding="UTF-8"/>
        </composite>

        <enum name="BooleanType" encodingType="uint8">
            <validValue name="FALSE">0</validValue>
            <validValue name="TRUE">1</validValue>
        </enum>

        <enum name="SnapOrderType" encodingType="uint8">
            <validValue name="LIMIT">1</validValue>
            <validValue name="MARKET">2</validValue>
        </enum>

        <enum name="SnapOrderSide" encodingType="uint8">
            <validValue name="BUY">1</validValue>
            <validValue name="SELL">2</validValue>
        </enum>

        <enum name="SnapTimeInForce" encodingType="uint8">
            <validValue name="GTC">1</validValue>
            <validValue name="IOC">2</validValue>
            <validValue name="FOK">3</validValue>
            <validValue name="POST_ONLY">4</validValue>
        </enum>

        <enum name="SnapStpStrategy" encodingType="uint8">
            <validValue name="DEFAULT">0</validValue>
            <validValue name="CANCEL_MAKER">1</validValue>
            <validValue name="CANCEL_TAKER">2</validValue>
            <validValue name="CANCEL_BOTH">3</validValue>
        </enum>

        <enum name="SnapOrderStatus" encodingType="uint8">
            <validValue name="NEW">1</validValue>
            <validValue name="CANCELLED">2</validValue>
            <validValue name="PARTIALLY_FILLED">3</validValue>
            <validValue name="FULL_FILLED">4</validValue>
            <validValue name="REJECTED">5</validValue>
        </enum>
    </types>

    <!-- 快照起始标记，携带全局状态 -->
    <message name="SnapshotHeader" id="300" description="快照起始，含全局单调序号">
        <field name="snapshotVersion" id="1" type="uint16"/>
        <field name="takenAtMillis" id="2" type="int64"/>
        <field name="maxProcessedRequestSerialNum" id="3" type="uint64"/>
        <field name="maxResultSerialNum" id="4" type="uint64"/>
    </message>

    <!-- 每个 symbol 的配置项 -->
    <message name="SymbolConfigEntry" id="301" description="币对配置">
        <field name="symbolCode" id="1" type="uint16"/>
        <field name="baseCoinId" id="2" type="uint32"/>
        <field name="quoteCoinId" id="3" type="uint32"/>
        <field name="enabled" id="4" type="BooleanType"/>
        <data name="symbolName" id="5" type="varStringEncoding"/>
    </message>

    <!-- OrderBook 起始标记，后续跟随的 MatchOrderEntry 隶属于此 symbol，直到下一个 OrderBookStart 或 SymbolSerialNumEntry -->
    <message name="OrderBookStart" id="302" description="OrderBook 起始">
        <field name="symbolCode" id="1" type="uint16"/>
        <field name="orderCount" id="2" type="uint32"/>
        <data name="symbolId" id="3" type="varStringEncoding"/>
    </message>

    <!-- OrderBook 中的一条订单 -->
    <message name="MatchOrderEntry" id="303" description="订单簿中的一个订单">
        <field name="orderId" id="1" type="uint64"/>
        <field name="accountId" id="2" type="uint64"/>
        <field name="orderType" id="3" type="SnapOrderType"/>
        <field name="orderSide" id="4" type="SnapOrderSide"/>
        <field name="timeInForce" id="5" type="SnapTimeInForce"/>
        <field name="stpStrategy" id="6" type="SnapStpStrategy"/>
        <field name="stpAccountId" id="7" type="uint64"/>
        <field name="orderStatus" id="8" type="SnapOrderStatus"/>
        <field name="createTime" id="9" type="int64"/>
        <field name="updateTime" id="10" type="int64"/>
        <data name="delegatePrice" id="11" type="varStringEncoding"/>
        <data name="delegateCount" id="12" type="varStringEncoding"/>
        <data name="dealtCount" id="13" type="varStringEncoding"/>
        <data name="clientOid" id="14" type="varStringEncoding"/>
    </message>

    <!-- 每个 symbol 的 serialNum 记录 -->
    <message name="SymbolSerialNumEntry" id="304" description="symbol 最后处理的 serialNum">
        <field name="symbolCode" id="1" type="uint16"/>
        <field name="lastRequestSerialNum" id="2" type="uint64"/>
        <field name="lastResultSerialNum" id="3" type="uint64"/>
    </message>

    <!-- 快照结束标记 -->
    <message name="SnapshotFooter" id="399" description="快照结束标记">
        <field name="totalEntries" id="1" type="uint32"/>
        <field name="checksum" id="2" type="uint64"/>
    </message>
</messageSchema>
